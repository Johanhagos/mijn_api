# Example environment variables for One.com SFTP helpers and deployment scripts
# Copy this to `.env` (or set vars in your environment) and fill with real values.

# One.com SFTP connection
ONE_SFTP_HOST=[REDACTED]
ONE_SFTP_USER=[REDACTED]
ONE_SFTP_PASSWORD=your-strong-password-here
ONE_SFTP_PORT=22
ONE_SFTP_REMOTE_ROOT=/webroots/dae9921c/

# Optional local path used by upload/deploy scripts
ONE_LOCAL_UPLOAD_PATH=c:/Users/gebruiker/Desktop/mijn_api/webshop_for_upload
