# Sample environment variables for merchant-dashboard / backend AI
# Do NOT put real API keys in this file. Use your deployment secret store (Vercel, GitHub Secrets, Railway, etc.)

# AI provider: 'openai' or 'google' (for Gemini/Vertex)
AI_PROVIDER=openai

# OpenAI - set this in your host or CI/CD secrets (do NOT commit the real key)
# OPENAI_API_KEY=<paste-your-key-in-deployment-secrets>

# Optional: choose which OpenAI model to use for ChatCompletion
# Examples: gpt-4o, gpt-4o-mini, gpt-4, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o

# Temperature & tokens for responses
OPENAI_TEMPERATURE=0.6
OPENAI_MAX_TOKENS=700
