{"pageProps":{"html":"<!DOCTYPE html>\r\n<html lang=\"en\">\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>APIBlockchain - Blockchain Payment Gateway & Smart Contract Invoicing</title>\r\n    <meta name=\"description\" content=\"Seamless blockchain payment gateway and smart contract invoicing for your webshop. Accept cryptocurrency payments with built-in compliance.\">\r\n    <link href=\"https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&family=Inter:wght@400;500;600&display=swap\" rel=\"stylesheet\">\r\n    <style>\r\n        * {\r\n            margin: 0;\r\n            padding: 0;\r\n            box-sizing: border-box;\r\n        }\r\n\r\n        body {\r\n            font-family: 'Inter', sans-serif;\r\n            line-height: 1.6;\r\n            color: #333;\r\n        }\r\n\r\n        /* Navigation */\r\n        nav {\r\n            position: sticky;\r\n            top: 0;\r\n            z-index: 1000;\r\n            background: rgba(255, 255, 255, 0.95);\r\n            backdrop-filter: blur(10px);\r\n            padding: 1rem 0;\r\n            border-bottom: 1px solid rgba(16, 185, 129, 0.1);\r\n        }\r\n\r\n        .nav-container {\r\n            max-width: 1200px;\r\n            margin: 0 auto;\r\n            padding: 0 2rem;\r\n            display: flex;\r\n            justify-content: space-between;\r\n            align-items: center;\r\n        }\r\n\r\n        .logo {\r\n            font-size: 1.5rem;\r\n            font-weight: 800;\r\n            background: linear-gradient(135deg, #10b981 0%, #059669 100%);\r\n            -webkit-background-clip: text;\r\n            -webkit-text-fill-color: transparent;\r\n            background-clip: text;\r\n            font-family: 'Montserrat', sans-serif;\r\n        }\r\n\r\n        .nav-links {\r\n            display: flex;\r\n            gap: 2rem;\r\n            list-style: none;\r\n        }\r\n\r\n        .nav-links a {\r\n            text-decoration: none;\r\n            color: #333;\r\n            font-weight: 500;\r\n            transition: color 0.3s;\r\n        }\r\n\r\n        .nav-links a:hover {\r\n            color: #10b981;\r\n        }\r\n\r\n        .cta-button {\r\n            background: linear-gradient(135deg, #10b981 0%, #059669 100%);\r\n            color: white;\r\n            padding: 0.75rem 1.5rem;\r\n            border-radius: 50px;\r\n            text-decoration: none;\r\n            font-weight: 600;\r\n            transition: transform 0.3s, box-shadow 0.3s;\r\n            border: none;\r\n            cursor: pointer;\r\n        }\r\n\r\n        .cta-button:hover {\r\n            transform: translateY(-2px);\r\n            box-shadow: 0 10px 25px rgba(16, 185, 129, 0.3);\r\n        }\r\n\r\n        /* Hero Section */\r\n        .hero {\r\n            background: linear-gradient(135deg, #10b981 0%, #059669 100%);\r\n            color: white;\r\n            padding: 6rem 2rem;\r\n            text-align: center;\r\n            min-height: 100vh;\r\n            display: flex;\r\n            align-items: center;\r\n            justify-content: center;\r\n        }\r\n\r\n        .hero-content {\r\n            max-width: 800px;\r\n            margin: 0 auto;\r\n        }\r\n\r\n        .hero h1 {\r\n            font-size: 3.5rem;\r\n            font-family: 'Montserrat', sans-serif;\r\n            margin-bottom: 1rem;\r\n            font-weight: 800;\r\n            line-height: 1.2;\r\n        }\r\n\r\n        .hero p {\r\n            font-size: 1.25rem;\r\n            margin-bottom: 2rem;\r\n            opacity: 0.95;\r\n            line-height: 1.8;\r\n        }\r\n\r\n        .hero-buttons {\r\n            display: flex;\r\n            gap: 1rem;\r\n            justify-content: center;\r\n            flex-wrap: wrap;\r\n        }\r\n\r\n        .btn-primary {\r\n            background: white;\r\n            color: #10b981;\r\n            padding: 1rem 2.5rem;\r\n            border-radius: 50px;\r\n            text-decoration: none;\r\n            font-weight: 700;\r\n            transition: all 0.3s;\r\n            border: none;\r\n            cursor: pointer;\r\n            font-size: 1rem;\r\n        }\r\n\r\n        .btn-primary:hover {\r\n            transform: translateY(-3px);\r\n            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);\r\n        }\r\n\r\n        .btn-secondary {\r\n            background: transparent;\r\n            color: white;\r\n            padding: 1rem 2.5rem;\r\n            border: 2px solid white;\r\n            border-radius: 50px;\r\n            text-decoration: none;\r\n            font-weight: 700;\r\n            transition: all 0.3s;\r\n            cursor: pointer;\r\n            font-size: 1rem;\r\n        }\r\n\r\n        .btn-secondary:hover {\r\n            background: white;\r\n            color: #10b981;\r\n        }\r\n\r\n        /* Features Section */\r\n        .features {\r\n            padding: 5rem 2rem;\r\n            background: #f8f9fa;\r\n        }\r\n\r\n        .features-container {\r\n            max-width: 1200px;\r\n            margin: 0 auto;\r\n        }\r\n\r\n        .section-title {\r\n            text-align: center;\r\n            font-size: 2.5rem;\r\n            font-family: 'Montserrat', sans-serif;\r\n            margin-bottom: 0.5rem;\r\n            color: #333;\r\n            font-weight: 800;\r\n        }\r\n\r\n        .section-subtitle {\r\n            text-align: center;\r\n            font-size: 1.1rem;\r\n            color: #666;\r\n            margin-bottom: 3rem;\r\n        }\r\n\r\n        .features-grid {\r\n            display: grid;\r\n            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\r\n            gap: 2rem;\r\n        }\r\n\r\n        .feature-card {\r\n            background: white;\r\n            padding: 2rem;\r\n            border-radius: 15px;\r\n            text-align: center;\r\n            transition: all 0.3s;\r\n            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);\r\n        }\r\n\r\n        .feature-card:hover {\r\n            transform: translateY(-10px);\r\n            box-shadow: 0 15px 40px rgba(16, 185, 129, 0.2);\r\n        }\r\n\r\n        .feature-icon {\r\n            font-size: 3rem;\r\n            margin-bottom: 1rem;\r\n        }\r\n\r\n        .feature-card h3 {\r\n            font-family: 'Montserrat', sans-serif;\r\n            font-size: 1.3rem;\r\n            margin-bottom: 0.5rem;\r\n            color: #333;\r\n        }\r\n\r\n        .feature-card p {\r\n            color: #666;\r\n            line-height: 1.8;\r\n        }\r\n\r\n        /* Pricing Section */\r\n        .pricing {\r\n            padding: 5rem 2rem;\r\n            background: white;\r\n        }\r\n\r\n        .pricing-container {\r\n            max-width: 1200px;\r\n            margin: 0 auto;\r\n        }\r\n\r\n        .pricing-grid {\r\n            display: grid;\r\n            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\r\n            gap: 2rem;\r\n            margin-top: 3rem;\r\n        }\r\n\r\n        .pricing-card {\r\n            background: #f8f9fa;\r\n            padding: 2rem;\r\n            border-radius: 15px;\r\n            border: 2px solid #e9ecef;\r\n            transition: all 0.3s;\r\n        }\r\n\r\n        .pricing-card.featured {\r\n            background: linear-gradient(135deg, #10b981 0%, #059669 100%);\r\n            color: white;\r\n            border: none;\r\n            transform: scale(1.05);\r\n            box-shadow: 0 20px 50px rgba(16, 185, 129, 0.3);\r\n        }\r\n\r\n        .pricing-card h3 {\r\n            font-family: 'Montserrat', sans-serif;\r\n            font-size: 1.5rem;\r\n            margin-bottom: 1rem;\r\n        }\r\n\r\n        .pricing-card .price {\r\n            font-size: 2.5rem;\r\n            font-weight: 800;\r\n            font-family: 'Montserrat', sans-serif;\r\n            margin-bottom: 0.5rem;\r\n        }\r\n\r\n        .pricing-card .period {\r\n            opacity: 0.8;\r\n            margin-bottom: 2rem;\r\n            font-size: 0.95rem;\r\n        }\r\n\r\n        .pricing-card ul {\r\n            list-style: none;\r\n            margin-bottom: 2rem;\r\n        }\r\n\r\n        .pricing-card li {\r\n            padding: 0.5rem 0;\r\n            border-bottom: 1px solid rgba(0, 0, 0, 0.1);\r\n        }\r\n\r\n        .pricing-card.featured li {\r\n            border-bottom-color: rgba(255, 255, 255, 0.2);\r\n        }\r\n\r\n        .pricing-card li:before {\r\n            content: \"✓ \";\r\n            color: #10b981;\r\n            font-weight: bold;\r\n            margin-right: 0.5rem;\r\n        }\r\n\r\n        .pricing-card.featured li:before {\r\n            color: #fff;\r\n        }\r\n\r\n        .pricing-card .btn-primary {\r\n            width: 100%;\r\n            text-align: center;\r\n            display: block;\r\n        }\r\n\r\n        .pricing-card.featured .btn-primary {\r\n            background: white;\r\n            color: #10b981;\r\n        }\r\n\r\n        /* CTA Section */\r\n        .cta-section {\r\n            background: linear-gradient(135deg, #10b981 0%, #059669 100%);\r\n            color: white;\r\n            padding: 4rem 2rem;\r\n            text-align: center;\r\n        }\r\n\r\n        .cta-section h2 {\r\n            font-size: 2rem;\r\n            font-family: 'Montserrat', sans-serif;\r\n            margin-bottom: 1rem;\r\n        }\r\n\r\n        .cta-section p {\r\n            font-size: 1.1rem;\r\n            margin-bottom: 2rem;\r\n            opacity: 0.95;\r\n        }\r\n\r\n        /* Footer */\r\n        footer {\r\n            background: #2c3e50;\r\n            color: white;\r\n            padding: 3rem 2rem;\r\n            text-align: center;\r\n        }\r\n\r\n        .footer-content {\r\n            max-width: 1200px;\r\n            margin: 0 auto;\r\n        }\r\n\r\n        .footer-links {\r\n            display: flex;\r\n            justify-content: center;\r\n            gap: 2rem;\r\n            flex-wrap: wrap;\r\n            margin-bottom: 2rem;\r\n        }\r\n\r\n        .footer-links a {\r\n            color: white;\r\n            text-decoration: none;\r\n            transition: color 0.3s;\r\n        }\r\n\r\n        .footer-links a:hover {\r\n            color: #10b981;\r\n        }\r\n\r\n        /* AI Assistant Button */\r\n        #aiButton {\r\n            position: fixed;\r\n            bottom: 30px;\r\n            right: 30px;\r\n            width: 60px;\r\n            height: 60px;\r\n            border-radius: 50%;\r\n            background: linear-gradient(135deg, #10b981 0%, #059669 100%);\r\n            color: white;\r\n            border: none;\r\n            cursor: pointer;\r\n            font-size: 1.5rem;\r\n            box-shadow: 0 5px 20px rgba(16, 185, 129, 0.4);\r\n            transition: all 0.3s;\r\n            z-index: 999;\r\n        }\r\n\r\n        #aiButton:hover {\r\n            transform: scale(1.1);\r\n            box-shadow: 0 10px 30px rgba(16, 185, 129, 0.6);\r\n        }\r\n\r\n        /* AI Widget */\r\n        .ai-widget {\r\n            position: fixed;\r\n            bottom: 100px;\r\n            right: 30px;\r\n            width: 350px;\r\n            max-height: 500px;\r\n            background: white;\r\n            border-radius: 15px;\r\n            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);\r\n            display: none;\r\n            flex-direction: column;\r\n            z-index: 998;\r\n            overflow: hidden;\r\n        }\r\n\r\n        .ai-widget.active {\r\n            display: flex;\r\n        }\r\n\r\n        .ai-header {\r\n            background: linear-gradient(135deg, #10b981 0%, #059669 100%);\r\n            color: white;\r\n            padding: 1rem;\r\n            display: flex;\r\n            justify-content: space-between;\r\n            align-items: center;\r\n        }\r\n\r\n        .ai-close {\r\n            background: none;\r\n            border: none;\r\n            color: white;\r\n            cursor: pointer;\r\n            font-size: 1.5rem;\r\n        }\r\n\r\n        .ai-messages {\r\n            flex: 1;\r\n            overflow-y: auto;\r\n            padding: 1rem;\r\n        }\r\n\r\n        .message {\r\n            margin-bottom: 1rem;\r\n            padding: 0.75rem;\r\n            border-radius: 10px;\r\n            max-width: 90%;\r\n        }\r\n\r\n        .message.assistant {\r\n            background: #f0f0f0;\r\n            align-self: flex-start;\r\n        }\r\n\r\n        .message.user {\r\n            background: #10b981;\r\n            color: white;\r\n            align-self: flex-end;\r\n            margin-left: auto;\r\n        }\r\n\r\n        .ai-input {\r\n            padding: 1rem;\r\n            border-top: 1px solid #e0e0e0;\r\n            display: flex;\r\n            gap: 0.5rem;\r\n        }\r\n\r\n        .ai-input input {\r\n            flex: 1;\r\n            border: 1px solid #ddd;\r\n            border-radius: 20px;\r\n            padding: 0.5rem 1rem;\r\n            font-size: 0.9rem;\r\n        }\r\n\r\n        .ai-input button {\r\n            background: #10b981;\r\n            color: white;\r\n            border: none;\r\n            border-radius: 50%;\r\n            width: 36px;\r\n            height: 36px;\r\n            cursor: pointer;\r\n            display: flex;\r\n            align-items: center;\r\n            justify-content: center;\r\n            transition: background 0.3s;\r\n        }\r\n\r\n        .ai-input button:hover {\r\n            background: #059669;\r\n        }\r\n\r\n        /* Responsive */\r\n        @media (max-width: 768px) {\r\n            .nav-links {\r\n                display: none;\r\n            }\r\n\r\n            .hero h1 {\r\n                font-size: 2rem;\r\n            }\r\n\r\n            .hero p {\r\n                font-size: 1rem;\r\n            }\r\n\r\n            .hero-buttons {\r\n                flex-direction: column;\r\n            }\r\n\r\n            .btn-primary, .btn-secondary {\r\n                width: 100%;\r\n            }\r\n\r\n            .section-title {\r\n                font-size: 1.8rem;\r\n            }\r\n\r\n            .ai-widget {\r\n                width: 90vw;\r\n                max-width: 350px;\r\n                bottom: 90px;\r\n                right: 5%;\r\n            }\r\n        }\r\n    </style>\r\n</head>\r\n<body>\r\n    <!-- Navigation -->\r\n    <nav>\r\n        <div class=\"nav-container\">\r\n            <div class=\"logo\">APIBlockchain</div>\r\n            <ul class=\"nav-links\">\r\n                <li><a href=\"#features\">Features</a></li>\r\n                <li><a href=\"#pricing\">Pricing</a></li>\r\n                <li><a href=\"#contact\">Contact</a></li>\r\n                <li><a href=\"https://dashboard.apiblockchain.io/login\" target=\"_blank\">Dashboard</a></li>\r\n            </ul>\r\n            <a class=\"cta-button\" href=\"/checkout.html?plan=professional&price=29.99\">Get Started</a>\r\n        </div>\r\n    </nav>\r\n\r\n    <!-- Hero Section -->\r\n    <section class=\"hero\">\r\n        <div class=\"hero-content\">\r\n            <h1>Blockchain Payments Made Simple</h1>\r\n            <p>Seamless cryptocurrency payment gateway and smart contract invoicing for your webshop. Accept blockchain payments with built-in compliance.</p>\r\n            <div class=\"hero-buttons\">\r\n                <a href=\"#pricing\" class=\"btn-primary\">View Pricing</a>\r\n                <a href=\"https://dashboard.apiblockchain.io/login\" class=\"btn-secondary\">Go to Dashboard</a>\r\n            </div>\r\n        </div>\r\n    </section>\r\n\r\n    <!-- Features Section -->\r\n    <section class=\"features\" id=\"features\">\r\n        <div class=\"features-container\">\r\n            <h2 class=\"section-title\">Why Choose APIBlockchain?</h2>\r\n            <p class=\"section-subtitle\">Everything you need for seamless blockchain payments</p>\r\n            \r\n            <div class=\"features-grid\">\r\n                <div class=\"feature-card\">\r\n                    <div class=\"feature-icon\">⚡</div>\r\n                    <h3>Lightning Fast</h3>\r\n                    <p>Process payments in seconds with instant blockchain confirmation</p>\r\n                </div>\r\n                \r\n                <div class=\"feature-card\">\r\n                    <div class=\"feature-icon\">🔒</div>\r\n                    <h3>Secure & Compliant</h3>\r\n                    <p>Military-grade encryption with full regulatory compliance built-in</p>\r\n                </div>\r\n                \r\n                <div class=\"feature-card\">\r\n                    <div class=\"feature-icon\">📊</div>\r\n                    <h3>Smart Invoicing</h3>\r\n                    <p>Automated invoice generation with blockchain proof of payment</p>\r\n                </div>\r\n                \r\n                <div class=\"feature-card\">\r\n                    <div class=\"feature-icon\">🌐</div>\r\n                    <h3>Multi-Currency</h3>\r\n                    <p>Accept payments in multiple cryptocurrencies and stablecoins</p>\r\n                </div>\r\n                \r\n                <div class=\"feature-card\">\r\n                    <div class=\"feature-icon\">🤖</div>\r\n                    <h3>AI-Powered</h3>\r\n                    <p>Smart contract automation with AI-driven payment optimization</p>\r\n                </div>\r\n                \r\n                <div class=\"feature-card\">\r\n                    <div class=\"feature-icon\">📈</div>\r\n                    <h3>Real Analytics</h3>\r\n                    <p>Detailed insights and reporting on all your blockchain transactions</p>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </section>\r\n\r\n    <!-- Dashboard Section -->\r\n    <section style=\"padding: 5rem 2rem; background: white;\">\r\n        <div style=\"max-width: 1200px; margin: 0 auto;\">\r\n            <h2 class=\"section-title\">Powerful Dashboard</h2>\r\n            <p class=\"section-subtitle\">Manage all your blockchain payments in one place</p>\r\n            \r\n            <div style=\"display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; margin-top: 3rem;\">\r\n                <div>\r\n                    <h3 style=\"font-size: 1.8rem; font-family: 'Montserrat', sans-serif; margin-bottom: 1.5rem; color: #333;\">Your Complete Payment Hub</h3>\r\n                    <ul style=\"list-style: none; padding: 0;\">\r\n                        <li style=\"padding: 1rem 0; border-bottom: 1px solid #eee; display: flex; align-items: center;\">\r\n                            <span style=\"color: #10b981; font-size: 1.5rem; margin-right: 1rem;\">✓</span>\r\n                            <span>Real-time transaction monitoring</span>\r\n                        </li>\r\n                        <li style=\"padding: 1rem 0; border-bottom: 1px solid #eee; display: flex; align-items: center;\">\r\n                            <span style=\"color: #10b981; font-size: 1.5rem; margin-right: 1rem;\">✓</span>\r\n                            <span>Automated invoice generation & tracking</span>\r\n                        </li>\r\n                        <li style=\"padding: 1rem 0; border-bottom: 1px solid #eee; display: flex; align-items: center;\">\r\n                            <span style=\"color: #10b981; font-size: 1.5rem; margin-right: 1rem;\">✓</span>\r\n                            <span>Multi-currency payment processing</span>\r\n                        </li>\r\n                        <li style=\"padding: 1rem 0; border-bottom: 1px solid #eee; display: flex; align-items: center;\">\r\n                            <span style=\"color: #10b981; font-size: 1.5rem; margin-right: 1rem;\">✓</span>\r\n                            <span>Advanced analytics & reporting</span>\r\n                        </li>\r\n                        <li style=\"padding: 1rem 0; border-bottom: 1px solid #eee; display: flex; align-items: center;\">\r\n                            <span style=\"color: #10b981; font-size: 1.5rem; margin-right: 1rem;\">✓</span>\r\n                            <span>User management & permissions</span>\r\n                        </li>\r\n                        <li style=\"padding: 1rem 0; border-bottom: 1px solid #eee; display: flex; align-items: center;\">\r\n                            <span style=\"color: #10b981; font-size: 1.5rem; margin-right: 1rem;\">✓</span>\r\n                            <span>API access for developers</span>\r\n                        </li>\r\n                    </ul>\r\n                    <a href=\"https://dashboard.apiblockchain.io/login\" target=\"_blank\" class=\"btn-primary\" style=\"display: inline-block; margin-top: 2rem;\">Access Dashboard</a>\r\n                </div>\r\n                \r\n                <div style=\"background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%); padding: 2rem; border-radius: 15px; box-shadow: 0 10px 30px rgba(16, 185, 129, 0.1);\">\r\n                    <div style=\"background: white; padding: 1.5rem; border-radius: 10px; margin-bottom: 1rem;\">\r\n                        <h4 style=\"color: #333; font-size: 0.9rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem; color: #666;\">Dashboard Overview</h4>\r\n                        <div style=\"display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;\">\r\n                            <span style=\"color: #666;\">Monthly Transactions</span>\r\n                            <span style=\"font-size: 1.5rem; font-weight: 800; color: #10b981;\">€45,230</span>\r\n                        </div>\r\n                        <div style=\"width: 100%; height: 6px; background: #e0e0e0; border-radius: 3px; overflow: hidden;\">\r\n                            <div style=\"width: 75%; height: 100%; background: linear-gradient(90deg, #10b981 0%, #059669 100%);\"></div>\r\n                        </div>\r\n                    </div>\r\n                    \r\n                    <div style=\"background: white; padding: 1.5rem; border-radius: 10px; margin-bottom: 1rem;\">\r\n                        <h4 style=\"color: #333; font-size: 0.9rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 1rem; color: #666;\">Recent Transactions</h4>\r\n                        <div style=\"display: flex; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid #eee;\">\r\n                            <span style=\"color: #333; font-size: 0.9rem;\">Payment from Client A</span>\r\n                            <span style=\"color: #10b981; font-weight: 600;\">+€1,200</span>\r\n                        </div>\r\n                        <div style=\"display: flex; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid #eee;\">\r\n                            <span style=\"color: #333; font-size: 0.9rem;\">Invoice #INV-001</span>\r\n                            <span style=\"color: #10b981; font-weight: 600;\">+€850</span>\r\n                        </div>\r\n                        <div style=\"display: flex; justify-content: space-between; padding: 0.75rem 0;\">\r\n                            <span style=\"color: #333; font-size: 0.9rem;\">Payout Processing</span>\r\n                            <span style=\"color: #666; font-weight: 600;\">-€500</span>\r\n                        </div>\r\n                    </div>\r\n                    \r\n                    <div style=\"background: white; padding: 1.5rem; border-radius: 10px;\">\r\n                        <h4 style=\"color: #333; font-size: 0.9rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 1rem; color: #666;\">Quick Stats</h4>\r\n                        <div style=\"display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;\">\r\n                            <div>\r\n                                <p style=\"color: #666; font-size: 0.85rem;\">Active Users</p>\r\n                                <p style=\"font-size: 1.5rem; font-weight: 800; color: #10b981;\">5</p>\r\n                            </div>\r\n                            <div>\r\n                                <p style=\"color: #666; font-size: 0.85rem;\">Success Rate</p>\r\n                                <p style=\"font-size: 1.5rem; font-weight: 800; color: #10b981;\">99.8%</p>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </section>\r\n\r\n    <!-- Pricing Section -->\r\n    <section class=\"pricing\" id=\"pricing\">\r\n        <div class=\"pricing-container\">\r\n            <h2 class=\"section-title\">Simple, Transparent Pricing</h2>\r\n            <p class=\"section-subtitle\">Choose the plan that fits your needs</p>\r\n            \r\n            <div class=\"pricing-grid\">\r\n                <div class=\"pricing-card\">\r\n                    <h3>Starter</h3>\r\n                    <div class=\"price\">€20</div>\r\n                    <div class=\"period\">/month</div>\r\n                    <ul>\r\n                        <li>Up to 100 transactions/month</li>\r\n                        <li>Basic invoicing</li>\r\n                        <li>Email support</li>\r\n                        <li>1 user account</li>\r\n                    </ul>\r\n                    <a class=\"btn-primary\" href=\"/checkout.html?plan=starter&price=20\">Get Started</a>\r\n                </div>\r\n\r\n                <div class=\"pricing-card featured\">\r\n                    <h3>Professional</h3>\r\n                    <div class=\"price\">€29.99</div>\r\n                    <div class=\"period\">/month</div>\r\n                    <ul>\r\n                        <li>Unlimited transactions</li>\r\n                        <li>Advanced smart contracts</li>\r\n                        <li>Priority 24/7 support</li>\r\n                        <li>Up to 5 user accounts</li>\r\n                        <li>API access</li>\r\n                        <li>Custom branding</li>\r\n                        <li>Real-time analytics</li>\r\n                        <li>Compliance reporting</li>\r\n                    </ul>\r\n                    <a class=\"btn-primary\" href=\"/checkout.html?plan=professional&price=29.99\">Choose Professional</a>\r\n                </div>\r\n\r\n                <div class=\"pricing-card\">\r\n                    <h3>Enterprise</h3>\r\n                    <div class=\"price\">Custom</div>\r\n                    <div class=\"period\">quote-based</div>\r\n                    <ul>\r\n                        <li>White-label solution</li>\r\n                        <li>Dedicated account manager</li>\r\n                        <li>Custom integrations</li>\r\n                        <li>Unlimited user accounts</li>\r\n                        <li>Priority support</li>\r\n                    </ul>\r\n                    <button class=\"btn-primary\" onclick=\"checkout('enterprise', 0)\">Contact Sales</button>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </section>\r\n\r\n    <!-- CTA Section -->\r\n    <section class=\"cta-section\" id=\"contact\">\r\n        <div class=\"cta-content\">\r\n            <h2>Ready to Transform Your Payments?</h2>\r\n            <p>Join thousands of webshop owners using APIBlockchain</p>\r\n            <button class=\"btn-secondary\" onclick=\"document.getElementById('aiButton').click()\">Chat with AI Assistant</button>\r\n        </div>\r\n    </section>\r\n\r\n    <!-- Domains Configuration -->\r\n    <section style=\"background: #f0f0f0; padding: 2rem; text-align: center; font-size: 0.85rem; color: #666;\">\r\n        <p style=\"margin-bottom: 1rem; font-weight: 600;\">🌐 Domains Configuration</p>\r\n        <p><strong>apiblockchain.io</strong> → Valid Configuration (307 Redirect)</p>\r\n        <p><strong>www.apiblockchain.io</strong> → Valid Configuration (Production) ✅</p>\r\n        <p><strong>dashboard.apiblockchain.io</strong> → Valid Configuration (Production) ✅</p>\r\n        <p><strong>merchant-dashboard-tau.vercel.app</strong> → Valid Configuration ✅</p>\r\n        <p style=\"margin-top: 1rem; font-size: 0.75rem; color: #999;\">DNS records propagating globally...</p>\r\n    </section>\r\n\r\n    <!-- Footer -->\r\n    <footer>\r\n        <div class=\"footer-content\">\r\n            <p>&copy; 2026 APIBlockchain. All rights reserved.</p>\r\n            <div class=\"footer-links\">\r\n                <a href=\"#\">Privacy Policy</a>\r\n                <a href=\"#\">Terms of Service</a>\r\n                <a href=\"#\">Contact</a>\r\n            </div>\r\n            <p>G.A. Brederodestraat 100, 1132 ST Volendam, Netherlands</p>\r\n            <p>Email: info@apiblockchain.io | Phone: +31 6 52 82 42 45</p>\r\n        </div>\r\n    </footer>\r\n\r\n    <!-- AI Assistant -->\r\n        <button id=\"connectWalletBtn\" style=\"position:fixed;top:30px;right:30px;background:#10b981;color:white;border:none;border-radius:50px;padding:0.75rem 1.5rem;font-weight:600;z-index:999;cursor:pointer;box-shadow:0 2px 8px rgba(16,185,129,0.15);\" onclick=\"connectWallet()\">Connect Wallet</button>\r\n        <div id=\"walletStatus\" style=\"position:fixed;top:70px;right:30px;background:#d1fae5;color:#333;border-radius:10px;padding:0.5rem 1rem;font-size:0.95rem;z-index:999;display:none;\"></div>\r\n    <button id=\"aiButton\" onclick=\"toggleAI()\">💬</button>\r\n    <div class=\"ai-widget\" id=\"aiWidget\">\r\n        <div class=\"ai-header\">\r\n            <h3>AI Assistant</h3>\r\n            <button class=\"ai-close\" onclick=\"toggleAI()\">×</button>\r\n        </div>\r\n        <div class=\"ai-messages\" id=\"aiMessages\"></div>\r\n        <div class=\"ai-input\">\r\n            <input type=\"text\" placeholder=\"Ask me anything...\" id=\"aiInput\" onkeypress=\"handleAIInput(event)\">\r\n            <button onclick=\"sendAIMessage()\">➤</button>\r\n        </div>\r\n    </div>\r\n\r\n    <script>\r\n                // Wallet connection: safe MetaMask detection + WalletConnect fallback\r\n                function loadScript(url) {\r\n                    return new Promise((resolve, reject) => {\r\n                        const s = document.createElement('script');\r\n                        s.src = url;\r\n                        s.async = true;\r\n                        s.onload = () => resolve();\r\n                        s.onerror = () => reject(new Error('Failed to load ' + url));\r\n                        document.head.appendChild(s);\r\n                    });\r\n                }\r\n\r\n                async function connectWithWeb3Modal(statusDiv) {\r\n                    try {\r\n                        // Load required libs dynamically (CDN)\r\n                        await loadScript('https://cdn.jsdelivr.net/npm/web3@1.8.2/dist/web3.min.js');\r\n                        await loadScript('https://unpkg.com/@walletconnect/web3-provider@1.7.8/dist/umd/index.min.js');\r\n                        await loadScript('https://unpkg.com/web3modal@1.9.8/dist/index.js');\r\n\r\n                        const providerOptions = {\r\n                            walletconnect: {\r\n                                package: window.WalletConnectProvider.default || window.WalletConnectProvider,\r\n                                options: {\r\n                                    infuraId: \"\" // Optional: add Infura ID or RPC mappings\r\n                                }\r\n                            }\r\n                        };\r\n\r\n                        const web3Modal = new window.Web3Modal.default({ cacheProvider: false, providerOptions });\r\n                        const provider = await web3Modal.connect();\r\n                        const web3 = new window.Web3(provider);\r\n                        const accounts = await web3.eth.getAccounts();\r\n                        if (accounts && accounts[0]) {\r\n                            statusDiv.textContent = 'Connected: ' + accounts[0];\r\n                            return { provider, account: accounts[0] };\r\n                        }\r\n                        statusDiv.textContent = 'Connected (no account found)';\r\n                        return null;\r\n                    } catch (err) {\r\n                        console.error('Web3Modal connection failed', err);\r\n                        statusDiv.textContent = 'Wallet connection failed: ' + (err.message || err);\r\n                        return null;\r\n                    }\r\n                }\r\n\r\n                async function connectWallet() {\r\n                    const statusDiv = document.getElementById('walletStatus');\r\n                    statusDiv.style.display = 'block';\r\n\r\n                    // If MetaMask is present, prefer it\r\n                    if (typeof window.ethereum !== 'undefined' && window.ethereum.isMetaMask) {\r\n                        try {\r\n                            const accounts = await window.ethereum.request({ method: 'eth_requestAccounts' });\r\n                            if (accounts && accounts[0]) {\r\n                                statusDiv.textContent = 'Connected: ' + accounts[0];\r\n                                return { provider: window.ethereum, account: accounts[0] };\r\n                            }\r\n                        } catch (err) {\r\n                            console.error('MetaMask connect error', err);\r\n                            statusDiv.textContent = 'MetaMask connection failed: ' + (err.message || err);\r\n                        }\r\n                    }\r\n\r\n                    // No MetaMask or connection failed — try Web3Modal (WalletConnect) fallback\r\n                    statusDiv.textContent = 'Opening wallet selector...';\r\n                    const result = await connectWithWeb3Modal(statusDiv);\r\n                    if (result) return result;\r\n\r\n                    // Final fallback: offer install link\r\n                    const installUrl = 'https://metamask.io/download.html';\r\n                    statusDiv.innerHTML = 'No wallet connected. <a href=\"' + installUrl + '\" target=\"_blank\" rel=\"noopener\">Install MetaMask</a> or try another wallet.';\r\n                    return null;\r\n                }\r\n\r\n                // Hide wallet status after a short time unless it contains a link\r\n                document.getElementById('connectWalletBtn').addEventListener('click', () => {\r\n                    setTimeout(() => {\r\n                        const s = document.getElementById('walletStatus');\r\n                        if (s && s.querySelector('a') === null) s.style.display = 'none';\r\n                    }, 6000);\r\n                });\r\n        function checkout(plan, amount) {\r\n            if (plan === 'enterprise') {\r\n                // For enterprise, show contact form\r\n                alert('Thank you for your interest in our Enterprise plan!\\n\\nPlease contact our sales team at:\\nEmail: sales@apiblockchain.io\\nPhone: +31 6 52 82 42 45');\r\n                window.location.href = 'mailto:sales@apiblockchain.io?subject=Enterprise%20Plan%20Inquiry';\r\n            } else {\r\n                const summary = plan.charAt(0).toUpperCase() + plan.slice(1);\r\n                const confirmed = confirm(`Complete ${summary} Plan Checkout?\\n\\nAmount: €${amount}\\n\\nClick OK to proceed to payment.`);\r\n                if (confirmed) {\r\n                    window.location.href = `/checkout.html?plan=${plan}&price=${amount}`;\r\n                }\r\n            }\r\n        }\r\n\r\n        // ...existing code...\r\n\r\n        function toggleAI() {\r\n            const widget = document.getElementById('aiWidget');\r\n            widget.classList.toggle('active');\r\n            if (widget.classList.contains('active')) {\r\n                document.getElementById('aiInput').focus();\r\n                // Initialize with welcome message\r\n                if (document.getElementById('aiMessages').children.length === 0) {\r\n                    addMessage('Hi! I\\'m APIBlockchain\\'s AI Assistant. How can I help you today?', 'assistant');\r\n                }\r\n            }\r\n        }\r\n\r\n        function addMessage(text, sender) {\r\n            const messagesDiv = document.getElementById('aiMessages');\r\n            const messageEl = document.createElement('div');\r\n            messageEl.className = `message ${sender}`;\r\n            messageEl.textContent = text;\r\n            messagesDiv.appendChild(messageEl);\r\n            messagesDiv.scrollTop = messagesDiv.scrollHeight;\r\n        }\r\n\r\n        function handleAIInput(event) {\r\n            if (event.key === 'Enter') {\r\n                sendAIMessage();\r\n            }\r\n        }\r\n\r\n        function sendAIMessage() {\r\n            const input = document.getElementById('aiInput');\r\n            const message = input.value.trim();\r\n            \r\n            if (!message) return;\r\n\r\n            addMessage(message, 'user');\r\n            input.value = '';\r\n\r\n            // Simulate AI response\r\n            setTimeout(() => {\r\n                const lower = message.toLowerCase().trim();\r\n                let response = '';\r\n\r\n                // Check for greetings first\r\n                if (lower === 'hi' || lower === 'hello' || lower.includes('hey') || \r\n                    lower.includes('how are you') || lower.includes('how do you do') || \r\n                    lower.includes('what\\'s up') || lower.includes('how\\'s it going') || \r\n                    lower === 'hola' || lower === 'bonjour' || lower === 'buenos días') {\r\n                    response = 'Hello! Welcome to APIBlockchain. 👋 I\\'m here to help with any questions about our blockchain payment gateway, cryptocurrency payments, smart contract invoicing, pricing, integration, or anything else. What would you like to know?';\r\n                } else if (lower.includes('price') || lower.includes('pricing') || lower.includes('cost') || lower.includes('plan')) {\r\n                    response = 'Starter is €20/month (up to 100 transactions). Professional is €29.99/month (unlimited transactions, dashboard, priority support). Enterprise is custom. Want the best plan for your volume?';\r\n                } else if (lower.includes('plugin') || lower.includes('woocommerce') || lower.includes('wordpress') || lower.includes('integrate')) {\r\n                    response = 'Install the APIBlockchain plugin, add your API key in settings, choose Web2/Web3 methods, and run a test checkout. Tell me your platform and I’ll give exact steps.';\r\n                } else if (lower.includes('crypto') || lower.includes('stablecoin') || lower.includes('usdt') || lower.includes('usdc')) {\r\n                    response = 'Yes, we support major stablecoins and cryptocurrencies including USDC, USDT, and ETH.';\r\n                } else if (lower.includes('api') || lower.includes('developer') || lower.includes('webhook')) {\r\n                    response = 'We provide a REST API with webhooks for real-time payment events and SDKs for common languages. Want a quick start guide?';\r\n                } else if (lower.includes('tax') || lower.includes('vat') || lower.includes('compliance')) {\r\n                    response = 'We handle tax compliance automatically across 60+ countries including EU VAT, US sales tax, and international regulations. Our system calculates taxes based on buyer/seller location and provides audit trails.';\r\n                } else if (lower.includes('pay') || lower.includes('payment') || lower.includes('checkout')) {\r\n                    response = 'Our payment gateway accepts both traditional payments (credit cards via PayPal) and cryptocurrencies (Bitcoin, Ethereum, stablecoins). You get instant settlement and transparent fees.';\r\n                } else if (lower.includes('invoice')) {\r\n                    response = 'Create smart contract invoices with automatic payment tracking, tax calculation, and multi-currency support. Customers can pay via Web2 or Web3 methods.';\r\n                } else if (lower.includes('refund') || lower.includes('return')) {\r\n                    response = 'Refunds are processed instantly. For crypto payments, we return funds to the original wallet. For traditional payments, credits go to the customer\\'s payment method.';\r\n                } else {\r\n                    const responses = [\r\n                        'That\\'s a great question! You can integrate blockchain payments into your webshop in just a few clicks.',\r\n                        'You\\'ll get instant notifications for all transactions and can access real-time analytics 24/7.',\r\n                        'We offer seamless API integration that works with most popular webshop platforms.',\r\n                        'Our platform supports both traditional and cryptocurrency payments with automatic compliance.',\r\n                        'Need help with something specific? I can answer questions about payments, crypto, tax compliance, invoicing, or integration.'\r\n                    ];\r\n                    response = responses[Math.floor(Math.random() * responses.length)];\r\n                }\r\n\r\n                addMessage(response, 'assistant');\r\n            }, 500);\r\n        }\r\n\r\n        // Suppress harmless browser extension errors\r\n        window.addEventListener('error', (event) => {\r\n            // Suppress MetaMask and other extension-related errors silently\r\n            if (event.filename && (event.filename.includes('inpage') || event.filename.includes('extension') || event.filename.includes('chrome-extension'))) {\r\n                event.preventDefault();\r\n                return false;\r\n            }\r\n        }, true);\r\n\r\n        window.addEventListener('unhandledrejection', (event) => {\r\n            // Suppress MetaMask connection errors if extension not installed\r\n            if (event.reason && event.reason.message && event.reason.message.includes('MetaMask')) {\r\n                event.preventDefault();\r\n                console.log('MetaMask not available - Web3 features disabled');\r\n            }\r\n        });\r\n    </script>\r\n</body>\r\n</html>\r\n\r\n\r\n"},"__N_SSG":true}